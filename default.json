{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "baseBranches": [
        "dev"
    ],
    "dependencyDashboard": true,
    "labels": [
        "dependencies"
    ],
    "branchPrefix": "deps/",
    "extends": [
        "config:base"
    ],
    "reviewers": [
        "RainbowDashLabs"
    ],
    "prConcurrentLimit": 3,
    "prHourlyLimit": 10,
    "packageRules": [
        {
            "matchManagers": [
                "npm"
            ],
            "stabilityDays": 14,
            "schedule": [
                "on friday"
            ]
        },
        {
            "matchManagers": [
                "pip_requirements",
                "pip_setup",
                "pipenv",
                "poetry",
                "pip-compile",
                "pyenv"
            ],
            "schedule": [
                "on thursday"
            ]
        },
        {
            "matchUpdateTypes": [
                "minor",
                "patch",
                "pin",
                "digest"
            ],
            "automerge": true,
            "squash": true,
            "automergeType": "branch"
        },
        {
            "matchManagers": [
                "github-actions",
                "maven",
                "gradle"
            ],
            "automerge": true,
            "squash": true,
            "automergeType": "branch"
        },
        {
            "groupName": "jackson",
            "matchPackagePatterns": [
                "^com\\.fasterxml\\.jackson\\.",
                "^tools\\.jackson"
            ]
        },
        {
            "groupName": "junit",
            "matchPackagePatterns": [
                "org.junit.jupiter:junit-jupiter-api",
                "org.junit.jupiter:junit-jupiter-engine",
                "org.junit:junit-bom"
            ]
        },
        {
            "groupName": "log4j",
            "matchPackagePatterns": [
                "^org\\.apache\\.logging\\.log4j:"
            ]
        },
        {
            "groupName": "sadu",
            "matchPackagePatterns": [
                "de.chojo.sadu"
            ]
        }
    ]
}
